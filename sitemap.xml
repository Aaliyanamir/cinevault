    <?php
    // Dynamically add all movies
    require_once 'includes/config.php';
    $db = getDB();
    $movies = $db->query("SELECT slug, updated_at FROM movies");
    while($m = $movies->fetch_assoc()) {
        echo "<url><loc>http://yourdomain.com/movie-detail.php?slug={$m['slug']}</loc><lastmod>{$m['updated_at']}</lastmod><priority>0.9</priority></url>";
    }
    ?>
